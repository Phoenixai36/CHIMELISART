---
/**
 * Navbar component
 */
import { t } from '@/stores/language';
import LanguageToggle from './LanguageToggle.astro';
import Cart from './react/Cart';
---
<header id="main-header" class="fixed top-0 left-0 w-full z-[100] transition-all duration-500 py-6">
  <div class="container-wide flex items-center justify-between">
    <!-- Logo -->
    <a href="/" class="flex items-center gap-3 group">
      <div class="w-10 h-10 bg-accent rounded-sm flex items-center justify-center group-hover:bg-white transition-colors duration-500">
        <span class="font-heading text-xl text-surface-dark font-bold">C</span>
      </div>
      <span class="font-heading text-lg font-bold text-white tracking-[0.3em] uppercase group-hover:text-accent transition-colors">
        CHIMELIS<span class="text-accent group-hover:text-white">ART</span>
      </span>
    </a>

    <!-- Desktop Nav -->
    <nav class="hidden lg:flex items-center gap-12">
      {[
        { key: 'gallery', path: '/gallery' },
        { key: 'writings', path: '/works' },
        { key: 'about', path: '/artist' },
        { key: 'store', path: '/tienda' }
      ].map((item) => (
        <a 
          href={item.path} 
          class="font-body text-[11px] uppercase tracking-[0.4em] text-muted-foreground hover:text-white transition-colors relative group py-2"
        >
          {t(`nav.${item.key}`)}
          <span class="absolute bottom-0 left-0 w-0 h-px bg-accent transition-all duration-500 group-hover:w-full"></span>
        </a>
      ))}
    </nav>

    <!-- Right Actions -->
    <div class="flex items-center gap-8">
      <div class="hidden md:block">
        <LanguageToggle />
      </div>
      
      <Cart client:load />

      <button id="mobile-menu-btn" class="lg:hidden text-white hover:text-accent transition-colors p-2" aria-label="Menu">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="4" x2="20" y1="12" y2="12"/><line x1="4" x2="20" y1="6" y2="6"/><line x1="4" x2="20" y1="18" y2="18"/></svg>
      </button>
    </div>
  </div>
</header>

<script>
  const header = document.getElementById('main-header');
  
  window.addEventListener('scroll', () => {
    if (window.scrollY > 50) {
      header?.classList.add('bg-surface-dark/90', 'backdrop-blur-xl', 'py-4', 'border-b', 'border-white/5');
      header?.classList.remove('py-6');
    } else {
      header?.classList.remove('bg-surface-dark/90', 'backdrop-blur-xl', 'py-4', 'border-b', 'border-white/5');
      header?.classList.add('py-6');
    }
  });
</script>
