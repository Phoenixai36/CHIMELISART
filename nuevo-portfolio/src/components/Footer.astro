---
/**
 * Footer component
 */
import { t } from '@/stores/language';
---
<footer class="bg-surface-dark py-20 border-t border-white/5 relative z-10 overflow-hidden">
  <div class="absolute inset-0 perspective-grid opacity-10 pointer-events-none"></div>
  
  <div class="container-wide">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12 mb-20">
      <div class="lg:col-span-2">
        <a href="/" class="font-heading text-2xl font-bold text-white tracking-[0.3em] uppercase mb-6 inline-block">
          CHIMELIS<span class="text-accent">ART</span>
        </a>
        <p class="text-muted-foreground font-body text-sm leading-relaxed max-w-sm mb-6">
          {t('hero.description')}
        </p>
        <div class="flex items-center gap-6">
          {['Instagram', 'Facebook', 'Vimeo'].map((social) => (
            <a href="#" class="text-muted-foreground hover:text-accent transition-colors duration-300">
              <span class="text-xs uppercase tracking-widest font-bold">{social}</span>
            </a>
          ))}
        </div>
      </div>

      <div>
        <h4 class="font-heading text-xs text-white uppercase tracking-[0.4em] mb-8">{t('nav.gallery')}</h4>
        <ul class="space-y-4">
          {['collections', 'writings', 'about', 'store'].map((key) => (
            <li>
              <a href={`/${key === 'store' ? 'tienda' : key}`} class="text-muted-foreground hover:text-white transition-colors text-sm uppercase tracking-widest font-body">
                {t(`nav.${key}`)}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <div>
        <h4 class="font-heading text-xs text-white uppercase tracking-[0.4em] mb-8">{t('acquisition.title')}</h4>
        <p class="text-muted-foreground text-sm font-body mb-4">Barcelona, Spain</p>
        <a href="mailto:info@chimelis.art" class="text-accent hover:text-white transition-colors text-sm font-bold tracking-widest underline decoration-accent/30 underline-offset-8">
          info@chimelis.art
        </a>
      </div>
    </div>

    <div class="pt-8 border-t border-white/5 flex flex-col md:flex-row items-center justify-between gap-6">
      <p class="text-[10px] text-muted-foreground uppercase tracking-widest">
        {t('footer.rights')}
      </p>
      <div class="flex items-center gap-8">
        <a href="#" class="text-[10px] text-muted-foreground uppercase tracking-widest hover:text-white transition-colors">Privacy Policy</a>
        <a href="#" class="text-[10px] text-muted-foreground uppercase tracking-widest hover:text-white transition-colors">Terms of Service</a>
      </div>
    </div>
  </div>
</footer>
