---
export const prerender = true;
import Layout from '@/layouts/Layout.astro';
import { t } from '@/stores/language';
---

<Layout title="Éxito" description="Pedido confirmado — Chimelis Art">
  <main class="h-hero flex items-center justify-center relative overflow-hidden">
    <div class="absolute inset-0 perspective-grid opacity-10"></div>
    
    <div class="container-narrow text-center relative z-10 animate-slide-up">
      <div class="mb-12 inline-flex items-center justify-center w-24 h-24 rounded-full border border-accent bg-accent/5">
        <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-accent"><polyline points="20 6 9 17 4 12"/></svg>
      </div>

      <h1 class="font-heading text-4xl md:text-6xl text-white uppercase tracking-tighter mb-6">
        ¡Gracias!
      </h1>
      
      <p class="text-muted-foreground font-body text-sm md:text-lg mb-12 max-w-md mx-auto leading-relaxed">
        Tu solicitud ha sido recibida correctamente. Nos pondremos en contacto contigo a la brevedad para coordinar los detalles de adquisición y envío.
      </p>

      <a 
        href="/" 
        class="inline-block px-10 py-5 bg-accent text-surface-dark font-bold uppercase tracking-[0.4em] text-[10px] hover:bg-white transition-all transform hover:-translate-y-1"
      >
        Volver al Inicio
      </a>
      
      <div class="mt-20 pt-20 border-t border-white/5">
        <p class="text-[10px] text-muted-foreground uppercase tracking-[0.4em]">Francesc Chimelis — Arte Contemporáneo</p>
      </div>
    </div>
  </main>
</Layout>
