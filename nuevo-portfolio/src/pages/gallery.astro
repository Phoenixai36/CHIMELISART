---
export const prerender = true;
import Layout from '@/layouts/Layout.astro';
import GalleryGrid from '@/components/GalleryGrid.astro';
import { t } from '@/stores/language';
---

<Layout title="Galería" description="Explora la colección completa de obras surrealistas de Francesc Chimelis">
  <main class="pt-40 pb-32">
    <div class="container-wide">
      <div class="flex flex-col md:flex-row items-end justify-between mb-20 gap-8 animate-slide-up">
        <div>
          <h1 class="font-heading text-4xl md:text-6xl text-white uppercase tracking-tighter mb-4 leading-none">
            {t('gallery.title')} <span class="text-accent">{t('gallery.subtitle')}</span>
          </h1>
          <p class="text-muted-foreground font-body text-xs uppercase tracking-[0.4em]">
            Cuatro décadas de Surrealismo Figurativo
          </p>
        </div>
        
        <!-- Quick Filters Stub -->
        <div class="flex gap-6 mt-8 md:mt-0">
          {['all', 'available', 'sold'].map((filter) => (
            <button class={`text-[10px] uppercase font-bold tracking-widest pb-1 border-b transition-colors ${filter === 'all' ? 'border-accent text-accent' : 'border-transparent text-muted-foreground hover:text-white'}`}>
              {t(`gallery.filters.${filter}`)}
            </button>
          ))}
        </div>
      </div>

      <GalleryGrid />
      
      <div class="mt-32 text-center">
        <p class="text-muted-foreground font-body text-[10px] uppercase tracking-[0.5em] animate-pulse">
          {t('gallery.swipe')}
        </p>
      </div>
    </div>
  </main>
</Layout>
