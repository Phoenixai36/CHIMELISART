# CHIMELISART - Art Portfolio Website
# React, Next.js, Vercel, Cloudflare

{
  "mcpServers": {
    "filesystem-chimelisart": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-filesystem", "K:/AGENTS/CHIMELISART"]
    },
    "github-chimelisart": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-github", "--repository", "K:/AGENTS/CHIMELISART"],
      "env": {
        "GITHUB_TOKEN": "${GITHUB_TOKEN}"
      }
    },
    "figma": {
      "command": "npx",
      "args": ["-y", "figma-mcp"],
      "env": {
        "FIGMA_ACCESS_TOKEN": "${FIGMA_ACCESS_TOKEN}"
      }
    }
  }
}
